# ===========================================
# TUP-Manila USMS Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your actual values

# Supabase - Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role Key - SERVER ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic API Key - For AI concern summarization
ANTHROPIC_API_KEY=your-anthropic-api-key

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
